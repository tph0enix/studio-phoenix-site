generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model trivia {
  item_id                     Int       @id @default(autoincrement())
  item_name                   String?
  topic_level_1               String?
  topic_level_2               String?
  is_checked_fact             Boolean?  @default(false)
  is_checked_voice            Boolean?  @default(false)
  is_checked_hook             Boolean?  @default(false)
  is_checked_interest         Boolean?  @default(false)
  is_checked_conciseness      Boolean?  @default(false)
  is_posted_question          Boolean?  @default(false)
  is_posted_answer            Boolean?  @default(false)
  is_staged_question          Boolean?  @default(false)
  is_staged_answer            Boolean?  @default(false)
  datetime_scheduled_question DateTime? @db.Timestamptz(6)
  datetime_scheduled_answer   DateTime? @db.Timestamptz(6)
  datetime_posted_question    DateTime? @db.Timestamptz(6)
  datetime_posted_answer      DateTime? @db.Timestamptz(6)
  question_opener             String?
  question_raw                String?
  question_images_url         String?
  question_source_links_url   String?
  question_post_link_urlstub  String?
  answer_raw                  String?
  answer_notes                String?
  answer_links_url            String?
  answer_post_link_urlstub    String?
}

model email_submissions {
  id           Int     @id @default(autoincrement())
  email_local  String?
  email_domain String?
  date_submit  String?

  @@unique([email_local, email_domain])
}

model activities {
  activity_id              Int       @id @default(autoincrement())
  activity_category_id     Int?
  activity_description     String?
  activity_timestamp_start DateTime? @db.Timestamptz(6)
  activity_timestamp_end   DateTime? @db.Timestamptz(6)
  include_weekends         Boolean?
  hours_daily              Decimal?  @db.Decimal
  project_id               Int?
}

model activity_categories {
  activity_category_id         Int     @id @default(autoincrement())
  activity_category_name       String?
  activity_category_definition String?
}

model companies {
  company_id   Int     @id @default(autoincrement())
  company_name String?
}

model email_verifications {
  verification_id Int       @id @default(autoincrement())
  email           String
  code            String
  expires_at      DateTime  @db.Timestamptz(6)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
}

model leads {
  lead_id       Int      @id @default(autoincrement())
  name          String?
  title         String?
  category      String?
  url           String?
  is_valid_lead Boolean?
  is_messaged   Boolean?
}

model projects {
  project_id          Int     @id @default(autoincrement())
  project_name        String?
  project_type        String?
  project_description String?
}

model results {
  result_id            Int      @id @default(autoincrement())
  project_id           Int?
  company_id           Int?
  activity_category_id Int?
  state_before_measure Decimal? @db.Decimal
  state_before_unit_id Int?
  state_after_measure  Decimal? @db.Decimal
  state_after_unit_id  Int?
  result_description   String?
}

model units {
  unit_id                     Int     @id @default(autoincrement())
  unit_name_long_plural       String?
  unit_name_short             String?
  base_unit_id                String?
  base_unit_count_numerator   String?
  base_unit_count_denominator String?
  unit_name_long_singular     String?
}
